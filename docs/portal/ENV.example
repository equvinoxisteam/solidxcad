# SolidX CAD — Environment Variables (TEMPLATE ONLY)
# Copy to deployment platform. NEVER commit real values.

# ─── App ─────────────────────────────────────────────────
NODE_ENV=production
APP_NAME=SolidX CAD
SUPPORT_EMAIL=support@yourdomain.com

# ─── URLs ────────────────────────────────────────────────
FRONTEND_URL=https://solidxcad.equvinoxis.com
CLIENT_URL=https://solidxcad.equvinoxis.com
API_URL=https://api.solidxcad.equvinoxis.com
CORS_ORIGINS=https://solidxcad.equvinoxis.com

# Production: use database name solidxcad (not enigma)
# MONGODB_URI=...mongodb.net/solidxcad?...
# S3_FOLDER_PREFIX=solidxcad

# ─── Auth ────────────────────────────────────────────────
JWT_SECRET=generate-a-long-random-string-min-32-chars
JWT_EXPIRE=7d
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-on-first-deploy

# ─── Database ────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/solidxcad?retryWrites=true&w=majority

# ─── Redis (job queue) ───────────────────────────────────
REDIS_URL=redis://default:PASSWORD@host:6379

# ─── AWS S3 + CDN ────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your-bucket-name
S3_FOLDER_PREFIX=solidxcad
S3_PUBLIC_URL=https://your-bucket.s3.us-east-1.amazonaws.com
AWS_CLOUDFRONT_DOMAIN=https://your-distribution.cloudfront.net

# ─── Stripe (USD billing) ────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── OpenRouter (AI) ─────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_FAST=anthropic/claude-3.5-haiku
OPENROUTER_MODEL_CAD=anthropic/claude-sonnet-4
OPENROUTER_MODEL_VISION=openai/gpt-4o
OPENROUTER_APP_NAME=SolidX CAD
OPENROUTER_SITE_URL=https://solidxcad.equvinoxis.com

# ─── Email (Gmail API) ───────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER=
GMAIL_REDIRECT_URI=https://developers.google.com/oauthplayground

# ─── step.parts (optional override) ──────────────────────
STEP_PARTS_API_URL=https://api.step.parts

# ─── Credits (defaults) ──────────────────────────────────
CREDITS_FREE_SIGNUP=100
CREDITS_PRO_MONTHLY=500

# ─── Worker ──────────────────────────────────────────────
TEXT_TO_CAD_ROOT=/app/vendor/text-to-cad
PYTHON_BIN=/app/.venv/bin/python
CAD_WORKER_CONCURRENCY=2
