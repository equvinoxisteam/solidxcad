NODE_ENV=production
PORT=4000
APP_NAME=SolidX CAD
SUPPORT_EMAIL=team@eco-dispose.com

FRONTEND_URL=https://solidxcad.equvinoxis.com
CLIENT_URL=https://solidxcad.equvinoxis.com
API_URL=https://api.solidxcad.equvinoxis.com
CORS_ORIGINS=https://solidxcad.equvinoxis.com
# VIEWER_URL origin is also merged into the API CORS allowlist automatically

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/solidxcad?retryWrites=true&w=majority
JWT_SECRET=change-me
JWT_EXPIRE=7d
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=
S3_FOLDER_PREFIX=solidxcad
S3_PUBLIC_URL=
# Optional — leave empty if you serve files from S3 directly (no CloudFront)
AWS_CLOUDFRONT_DOMAIN=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
PRO_PLAN_AMOUNT_USD=20
CREDITS_FREE_SIGNUP=100
CREDITS_PRO_MONTHLY=500

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER=
GMAIL_REDIRECT_URI=

# Google sign-in — create a separate "Web application" OAuth client (NOT the Gmail mail client)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Authorized JavaScript origins: http://localhost:3000 (+ your production web URL)
# Authorized redirect URIs: http://localhost:4000/api/auth/google/callback (+ production API URL)

OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL_CAD=anthropic/claude-opus-4.7
OPENROUTER_MODEL_FAST=anthropic/claude-opus-4.7
OPENROUTER_MODEL_FALLBACK=anthropic/claude-opus-4.7
OPENROUTER_MAX_TOKENS=8192

# Optional Pinecone engineering knowledge base (vector RAG)
# PINECONE_API_KEY=
# PINECONE_INDEX_HOST=your-index-xxxx.svc.region.pinecone.io
# PINECONE_NAMESPACE=engineering
# PINECONE_TOP_K=5
# PINECONE_EMBED_MODEL=openai/text-embedding-3-small

TEXT_TO_CAD_ROOT=../../
PYTHON_BIN=

# CAD Viewer — local dev auto-starts on 4178; cloud uses a separate Railway viewer service
# Local: VIEWER_URL=http://127.0.0.1:4178  AUTO_START_VIEWER=true
# Production (Railway):
VIEWER_URL=https://viewer.solidxcad.equvinoxis.com
AUTO_START_VIEWER=false
VIEWER_CLOUD_MODE=true
VIEWER_CATALOG_TOKEN_EXPIRE=1h

# Slicing — production uses SolidX built-in mesh slicer (no GitHub/Orca download).
# Set SLICER_BACKEND=external and ORCASLICER_BIN locally to use OrcaSlicer instead.
SLICER_BACKEND=builtin

# Set to false to enforce credit limits in production
CREDITS_UNLIMITED=true

# File storage: local (default in dev), s3, or auto (try S3 then fallback)
# S3 Access Denied? Use local — files go to text-to-cad/tmp/solidxcad-storage/
# local for dev only — use s3 on Railway/production
STORAGE_BACKEND=s3
